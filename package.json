{
  "name": "personal-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "packages/*",
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "pnpm --recursive --if-present dev",
    "dev:agent": "cd apps/agent && uvicorn main:app --reload --host 0.0.0.0 --port ${AGENT_PORT:-4000}",
    "build": "pnpm --recursive --if-present build",
    "typecheck": "pnpm --filter @personal-agent/shared build && pnpm --recursive --if-present typecheck",
    "start:api": "pnpm --filter @personal-agent/api start",
    "start:agent": "cd apps/agent && uvicorn main:app --host 0.0.0.0 --port ${AGENT_PORT:-4000}",
    "start:web": "pnpm --filter @personal-agent/web preview"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3"
  }
}
